<?xml version="1.0" encoding="utf-8"?>
<mujoco model="crank_bot_scene">

  <compiler angle="radian"
            meshdir="assets"
            inertiafromgeom="true"
            autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.002"/>
 
 <include file="crank_bot.mjx.xml"/>

  <visual>
    <quality shadowsize="2048"/>
    <map znear="0.001" zfar="50"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             width="512" height="512"/>

    <material name="grid_mat"
              texture="grid"
              texrepeat="20 20"
              reflectance="0.2"/>
  </asset>

  <worldbody>
    <light name="sun"
           pos="0 0 2.5"
           dir="0 0 -1"
           directional="true"
           diffuse="0.8 0.8 0.8"
           specular="0.2 0.2 0.2"/>

    <geom name="floor"
          type="plane"
          size="2 2 0.05"
          pos="0 0 0"
          material="grid_mat"
          friction="1 0.005 0.0001"/>

    <camera name="overview"
            pos="0.35 -0.55 0.35"
            xyaxes="0.84 0.54 0 -0.25 0.39 0.89"/>
  </worldbody>

</mujoco>